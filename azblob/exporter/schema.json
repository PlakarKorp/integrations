{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plakar Azure Blob Exporter Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "location"
  ],
  "properties": {
    "location": {
      "type": "string",
      "minLength": 1,
      "description": "Azure Blob location URI: azblob://<container>/<optional-prefix>",
      "pattern": "^azblob://[^/]+(/.*)?$"
    },
    "connection_string": {
      "type": "string",
      "minLength": 1,
      "description": "Azure Blob Storage connection string"
    },
    "account_name": {
      "type": "string",
      "minLength": 1,
      "description": "Azure Storage account name"
    },
    "account_key": {
      "type": "string",
      "minLength": 1,
      "description": "Azure Storage account key"
    },
    "endpoint": {
      "type": "string",
      "minLength": 1,
      "description": "Azure Blob service endpoint, for example https://<account>.blob.core.windows.net or an Azurite endpoint"
    },
    "no_auth": {
      "type": "boolean",
      "default": false,
      "description": "Disable authentication, useful for public blobs or specific emulator/test setups"
    },
    "use_managed_identity": {
      "type": "boolean",
      "default": false,
      "description": "Enable Azure AD authentication via DefaultAzureCredential (supports system-assigned and user-assigned managed identity)"
    },
    "managed_identity_client_id": {
      "type": "string",
      "minLength": 1,
      "description": "Optional client ID for user-assigned managed identity"
    }
  },
  "oneOf": [
    {
      "required": [
        "location",
        "connection_string"
      ],
      "not": {
        "properties": {
          "use_managed_identity": {
            "const": true
          }
        }
      }
    },
    {
      "required": [
        "location",
        "account_name",
        "account_key"
      ],
      "not": {
        "properties": {
          "use_managed_identity": {
            "const": true
          }
        }
      }
    },
    {
      "required": [
        "location",
        "endpoint",
        "no_auth"
      ],
      "properties": {
        "no_auth": {
          "const": true
        }
      },
      "not": {
        "properties": {
          "use_managed_identity": {
            "const": true
          }
        }
      }
    },
    {
      "required": [
        "location",
        "use_managed_identity",
        "account_name"
      ],
      "properties": {
        "use_managed_identity": {
          "const": true
        }
      }
    },
    {
      "required": [
        "location",
        "use_managed_identity",
        "endpoint"
      ],
      "properties": {
        "use_managed_identity": {
          "const": true
        }
      }
    }
  ]
}