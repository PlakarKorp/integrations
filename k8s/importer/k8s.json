{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plakar K8S Importer Connector Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "location"
  ],
  "properties": {
    "location": {
      "type": "string",
      "minLength": 1,
      "description": "optional endpoint with optional namespace"
    },
    "labels": {
      "type": "string",
      "description": "optional kubernetes label selector"
    }
  }
}
